    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug lakeside",
            "program": "${workspaceFolder}/target/debug/lakeside",
            "args": [
                "--fixed-amount",
                "0",
                "--range-lower-bound",
                "10",
                "--range-upper-bound",
                "50",
                "--token-count",
                "4",
                "--mint",
                "https://testnut.cashu.space"
            ],
            "cwd": "${workspaceFolder}"
        }
    ]
}